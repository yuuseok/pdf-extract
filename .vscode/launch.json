{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: FastAPI Backend-local",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "app.main:app",
        "--reload",
        "--reload-dir",
        "app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001"
        // "--log-config", "log_config_local.yaml",
        // "--workers", "1"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "env": {
        "LANGCHAIN_TRACING_V2": "false"
      }
    },
    {
      "name": "Python: FastAPI Backend-dev",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "app.main:app",
        "--reload",
        "--reload-dir",
        "app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001"
        // "--log-config", "log_config_dev.yaml",
        // "--workers", "1"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.dev",
      "justMyCode": false,
      "env": {
        "LANGCHAIN_TRACING_V2": "false"
      }
    },
    {
      "name": "Python: FastAPI Backend-prod",
      "type": "debugpy",
      "request": "launch",
      "module": "gunicorn",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["app.main:app", "-k", "uvicorn.workers.UvicornWorker", "--bind", "0.0.0.0:8001", "--workers", "3"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.prod",
      "justMyCode": false,
      "env": {
        "LANGCHAIN_TRACING_V2": "false"
      }
    }
  ]
}
